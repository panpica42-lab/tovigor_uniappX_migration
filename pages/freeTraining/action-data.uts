export function getFreeTrainingAction(id: number): FreeTrainingAction | null {
	const found = freeTrainingActions.find((action: FreeTrainingAction): boolean => action.id == id)
	if (found == null) return null
	return cloneAction(found)
}

export function cloneAction(action: FreeTrainingAction): FreeTrainingAction {
	return {
		id: action.id,
		name: action.name,
		cover: action.cover,
		part: action.part,
		method: action.method,
		equipment: action.equipment,
		modeKey: action.modeKey,
		modeLabel: action.modeLabel,
		forceMode: action.forceMode,
		defaultResistance: action.defaultResistance,
		recommendedSets: action.recommendedSets,
		recommendedReps: action.recommendedReps,
		sets: action.sets,
		reps: action.reps
	}
}

export function cloneActions(actions: FreeTrainingAction[]): FreeTrainingAction[] {
	return actions.map((action: FreeTrainingAction): FreeTrainingAction => cloneAction(action))
}
