export const actionFilters: ActionFilter[] = [
	{ key: 'part', label: '部位', values: ['全部', '胸部', '肩部', '手臂', '腰腹', '背部', '腿部'] },
	{ key: 'method', label: '方式', values: ['全部', '有力臂', '无力臂'] },
	{ key: 'equipment', label: '配件', values: ['全部', '双肩把手', '脚环', '三角把手', '中杆', '横杆', '绳索'] }
]

export function getFreeTrainingMode(key: string): FreeTrainingMode {
	const found = freeTrainingModes.find((mode: FreeTrainingMode): boolean => mode.key == key)
	return found != null ? found : freeTrainingModes[0]
}

function createAction(id: number, name: string, coverFile: string, part: string, method: string, equipment: string, modeKey: string, resistance: number, sets: number, reps: number): FreeTrainingAction {
	const mode = getFreeTrainingMode(modeKey)
	return {
		id,
		name,
		cover: '/static/icons/freeTrainingActivity/action-library/' + coverFile,
		part,
		method,
		equipment,
		modeKey: mode.key,
		modeLabel: mode.shortName,
		forceMode: mode.forceMode,
		defaultResistance: resistance,
		recommendedSets: sets,
		recommendedReps: reps,
		sets,
		reps
	}
}

