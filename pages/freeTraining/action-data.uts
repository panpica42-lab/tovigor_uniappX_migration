import { FORCE_MODE } from '@/utils/serialRuntime.uts'

export type FreeTrainingMode = {
	key: string
	title: string
	shortName: string
	description: string
	icon: string
	forceMode: number
}

export type FreeTrainingAction = {
	id: number
	name: string
	cover: string
	part: string
	method: string
	equipment: string
	modeKey: string
	modeLabel: string
	forceMode: number
	defaultResistance: number
	recommendedSets: number
	recommendedReps: number
	sets: number
	reps: number
}

export type ActionFilter = {
	key: string
	label: string
	values: string[]
}

